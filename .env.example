# Global
PROJECT_NAME=CareerPilot
APP_ENV=development

# Backend
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=postgresql+psycopg://careerpilot:your_database_password@postgres:5432/careerpilot
TEST_DATABASE_URL=sqlite+pysqlite:///:memory:
REDIS_URL=redis://redis:6379/0
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_BUCKET=careerpilot
MINIO_SECURE=false
LOCAL_STORAGE_ROOT=backend/uploads
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password
LLM_PROVIDER=mock
OCR_PROVIDER=mock
RAGFLOW_PROVIDER=mock
GRAPH_PROVIDER=mock
STORAGE_PROVIDER=local
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
JWT_SECRET_KEY=your_secret_key_here_change_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
ERNIE_API_KEY=your_ernie_api_key
ERNIE_SECRET_KEY=your_ernie_secret_key
ERNIE_BASE_URL=https://aistudio.baidu.com/llm/lmapi/v3
ERNIE_MODEL=ernie-4.5-turbo-128k
PADDLE_OCR_SERVICE_URL=
RAGFLOW_BASE_URL=
RAGFLOW_API_KEY=
REPORT_EXPORT_DIR=exports
SCHEDULER_TIMEZONE=Asia/Shanghai

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
