# ============================================
# CareerPilot 配置文件
# 使用方法：复制此文件为 .env 即可启动
#   cp .env.example .env
# 默认配置使用 SQLite + Mock AI，开箱即用无需额外服务
# ============================================

# ---- 全局 ----
PROJECT_NAME=CareerPilot
APP_ENV=development

# ---- 后端 ----
API_HOST=0.0.0.0
API_PORT=8000
LOCAL_STORAGE_ROOT=backend/uploads
STORAGE_PROVIDER=local
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
JOB_DATASET_PATH=C:/Users/Lenovo/Downloads/20260226105856_457.xls
JOB_DATASET_FILTERING_ENABLED=true
JOB_DATASET_SCOPE=campus

# JWT（生产环境请替换为随机字符串）
JWT_SECRET_KEY=change_this_to_a_random_string_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# AI 模型（默认 mock 开箱即用；配置 token 后可切换为 ernie）
LLM_PROVIDER=mock
OCR_PROVIDER=mock
RAGFLOW_PROVIDER=mock
GRAPH_PROVIDER=mock

# ---- 如需使用 ERNIE 大模型，取消下方注释并填入 token ----
# LLM_PROVIDER=ernie
# ERNIE_ACCESS_TOKEN_ENCRYPTED=你的加密token
# ERNIE_AISTUDIO_BASE_URL=https://aistudio.baidu.com/llm/lmapi/v3
# ERNIE_MODEL=ernie-5.0-thinking-preview

# ---- PaddleOCR layout parsing service ----
# OCR_PROVIDER=paddle
# PADDLE_OCR_SERVICE_URL=https://rdj6r9sbc98duaa1.aistudio-app.com/layout-parsing
# PADDLE_OCR_API_KEY_ENCRYPTED=your_encrypted_token

# ---- 前端 ----
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

REPORT_EXPORT_DIR=exports
SCHEDULER_TIMEZONE=Asia/Shanghai
